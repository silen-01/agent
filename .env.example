# Локальная разработка (npm run dev): ключ читается только в dev и не попадает в production bundle.
VITE_GEMINI_API_KEY=your_key_here

# Прод (Vercel / сервер): задайте в Environment Variables проекта, не в .env.
# GEMINI_API_KEY=your_key_here
# Ключ отдаётся клиенту только через GET /api/live-token (serverless).
